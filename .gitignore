# ═══════════════════════════════════════════════════════════════
#  Health Stack System — .gitignore
#  Django + Python + VS Code + Windows/macOS/Linux
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
# PYTHON
# ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST


# ───────────────────────────────────────────────────────────────
# VIRTUAL ENVIRONMENTS
# ───────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
env_dir/
.env_dir/
Env/
virtualenv/
.virtualenv/
.Python


# ───────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES & SECRETS
# ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
local_settings.py


# ───────────────────────────────────────────────────────────────
# DJANGO
# ───────────────────────────────────────────────────────────────

# SQLite database (dev only — never commit to production)
db.sqlite3
db.sqlite3-journal
*.db

# Static & media files (generated at runtime)
/staticfiles/
/mediafiles/
/static/collected/
media/

# Django migrations (optional — uncomment to ignore)
# */migrations/*.py
# !*/migrations/__init__.py

# Django secret key & local config
local_settings.py
healthstack/local_settings.py


# ───────────────────────────────────────────────────────────────
# TESTING & COVERAGE
# ───────────────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
*.py,cover
nosetests.xml
pytest.ini
.pytest_cache/
test-results/
test_output/


# ───────────────────────────────────────────────────────────────
# PACKAGE DISTRIBUTION
# ───────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/
MANIFEST


